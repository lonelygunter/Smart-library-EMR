            "rdfs:label": [
                {
                    "@language": "en",
                    "@value": "abstract"
                }
            ]
        },
        {
            "@id": "schema:author",
            "@type": "ngsi-ld:Property",
            "rdfs:comment": [
                {
                    "@language": "en",
                    "@value": "The author of this content or rating. Please note that author is special in that HTML 5 provides a special mechanism for indicating authorship via the rel tag. That is equivalent to this and may be used interchangeably."
                }
            ],
            "rdfs:label": [
                {
                    "@language": "en",
                    "@value": "author"
                }
            ]
        },
